---
import type { VerticalCompetitor, CompetitorCell } from '../content/verticals/types';

interface Props {
  competitor?: VerticalCompetitor;
}
const { competitor } = Astro.props;

const CHECK = `<span class="check-icon"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 6l3 3 5-6"/></svg></span>`;
const X = `<span class="x-icon"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 3l6 6m0-6l-6 6"/></svg></span>`;
function cell(v: CompetitorCell): string {
  return v === 'check' ? CHECK : v === 'x' ? X : '—';
}

const col = competitor ?? {
  name: 'Calendly',
  rows: ['check', 'check', 'x', 'x', 'x', 'x', 'x'] as [
    CompetitorCell,
    CompetitorCell,
    CompetitorCell,
    CompetitorCell,
    CompetitorCell,
    CompetitorCell,
    CompetitorCell,
  ],
};
---

<section class="section">
  <div class="container">
    <div class="section-eyebrow">Comparativa</div>
    <h2 class="section-title">¿Por qué no seguir como vas?</h2>
    <p class="section-subtitle">
      Un vistazo honesto a cómo se compara <strong class="brand-mention"
        >agenda<span class="brand-llena">llena</span></strong
      > con las alternativas que probablemente ya estás usando.
    </p>

    <div class="comparison-wrap">
      <table class="comparison">
        <thead>
          <tr>
            <th>Funcionalidad</th>
            <th class="agendallena-col">agendallena</th>
            <th>Libreta</th>
            <th>WhatsApp</th>
            <th>{col.name}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Confirmación automática</td>
            <td class="agendallena-col"
              ><span class="check-icon"
                ><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"
                  ><path d="M2 6l3 3 5-6"></path></svg
                ></span
              ></td
            >
            <td
              ><span class="x-icon"
                ><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"
                  ><path d="M3 3l6 6m0-6l-6 6"></path></svg
                ></span
