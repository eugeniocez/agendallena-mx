                  ><path d="M3 3l6 6m0-6l-6 6"></path></svg
                ></span
              ></td
            >
            <td set:html={cell(col.rows[0])} />
          </tr>
          <tr>
            <td>Recordatorios automáticos</td>
            <td class="agendallena-col"
              ><span class="check-icon"
