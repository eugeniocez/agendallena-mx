---
interface Props {
  heading?: string;
  body?: string;
}
const { heading, body } = Astro.props;
---

<section class="final-cta" id="empezar">
  <div class="final-cta-content">
    {
      heading ? (
        <h2
          set:html={heading.replace(
            'agendallena',
            '<strong class="brand-mention">agenda<span class="brand-llena">llena</span></strong>'
          )}
        />
      ) : (
        <h2>
          En 5 minutos
          <br />
          estás <span class="accent">operando.</span>
        </h2>
      )
    }
    {
      body ? (
        <p
          set:html={body.replace(
            'agendallena',
            '<strong class="brand-mention">agenda<span class="brand-llena">llena</span></strong>'
          )}
        />
      ) : (
        <p>
          Sin instalaciones, sin onboarding largo, sin llamadas con vendedores. Te registras,
          agendas tu primera cita, y{' '}
          <strong class="brand-mention">
            agenda<span class="brand-llena">llena</span>
          </strong>{' '}
          empieza a trabajar.
        </p>
      )
    }
    <div class="final-cta-buttons">
      <a href="https://app.agendallena.mx/registro" class="btn btn-primary-lg"> Empezar gratis </a>
      <a href="#demo" class="btn btn-secondary-lg">
        <svg style="width:14px;height:14px" viewBox="0 0 14 14" fill="currentColor"
          ><path d="M3 2.5v9l8-4.5z"></path></svg
        >
        Ver demo
      </a>
    </div>
  </div>
</section>
