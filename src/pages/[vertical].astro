---
import type { GetStaticPaths } from 'astro';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import StatementStrip from '../components/StatementStrip.astro';
import SocialProof from '../components/SocialProof.astro';
import Problema from '../components/Problema.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Modules from '../components/Modules.astro';
import Comparison from '../components/Comparison.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { allVerticals } from '../content/verticals/index';
import type { VerticalContent } from '../content/verticals/types';

export const getStaticPaths = (() => {
  return allVerticals.map((v) => ({
    params: { vertical: v.slug },
    props: { content: v },
  }));
}) satisfies GetStaticPaths;

const { content } = Astro.props as { content: VerticalContent };
const canonical = `https://citas.bot/${content.slug}`;

const audienceLabel = content.hero.eyebrow.replace(/^Para\s+/i, '').toLowerCase();

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${content.serviceSchema.serviceType} para ${audienceLabel}`,
  "provider": {
    "@type": "Organization",
    "name": "citas.bot",
    "url": "https://citas.bot"
  },
  "areaServed": { "@type": "Country", "name": "México" },
  "serviceType": content.serviceSchema.serviceType,
  "audience": {
    "@type": "BusinessAudience",
    "audienceType": content.serviceSchema.audience
  },
  "offers": {
    "@type": "Offer",
    "price": "199",
    "priceCurrency": "MXN",
    "url": canonical
  }
};
---
<Base
  title={content.meta.title}
  description={content.meta.description}
  canonical={canonical}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)}></script>
  <Hero
    eyebrow={content.hero.eyebrow}
    h1={content.hero.h1}
    subtitle={content.hero.subtitle}
  />
  <StatementStrip />
  <SocialProof />
  <Problema cards={content.problema.cards} />
  <HowItWorks />
  <Modules />
  <Comparison />
  <Testimonials
    heading={content.testimonials.heading}
    items={content.testimonials.items}
  />
  <Pricing />
  <FAQ />
  <FinalCTA />
</Base>
