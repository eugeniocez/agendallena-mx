---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import StatementStrip from '../components/StatementStrip.astro';
import SocialProof from '../components/SocialProof.astro';
import Problema from '../components/Problema.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Modules from '../components/Modules.astro';
import Comparison from '../components/Comparison.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
---

<style is:global>
  :root {
    --verde: #1d4ed8;
    --verde-hover: #1e40af;
    --verde-tenue: #eff6ff;
    --verde-superficie: #1e3a5f;
    --verde-acento: #93c5fd;
    --hueso: #f8faff;
  }
</style>
<Base
  title="agendallena — Tu agenda, confirmada."
  description="La solución que confirma tu agenda por ti. Menos inasistencias, más certeza. Para clínicas, estilistas, terapeutas y todo negocio que vive de citas. $199 MXN/mes."
  noindex={true}
  canonicalBase="https://agendallena.mx/"
>
  <Hero
    h1='Cada inasistencia es<br><span class="accent">dinero que se va.</span>'
    subtitle="Los negocios que viven de citas pierden hasta una semana de ingresos al mes. Sin saber por qué, sin poder pararlo. agendallena confirma cada cita por ti — automáticamente."
  />
  <SocialProof />
  <StatementStrip />
  <Problema
    cards={[
      {
        title: 'Un hueco en la agenda',
        description:
          'Cada cita que no llega es ingreso que no entra. Y nadie te avisó. Nadie te compensó. Simplemente no llegó.',
      },
      {
        title: 'WhatsApp no es un sistema',
        description:
          'Mandar confirmaciones por WhatsApp funciona hasta que tienes 20 clientes. Después se pierde, se olvida y la cita tampoco llega.',
      },
      {
        title: 'El mes que no cuadra',
        description:
          'Trabajas el mes entero pero los números no cierran. Las inasistencias son silenciosas pero constantes. Se acumulan.',
      },
    ]}
  />
  <HowItWorks />
  <Modules />
  <Comparison />
  <Testimonials />
  <Pricing />
  <FAQ />
  <FinalCTA
    heading="Para de perder dinero<br>en citas que no llegan."
    body="agendallena confirma cada cita por ti — SMS, WhatsApp y llamada automática. En 5 minutos estás operando. Sin contratos, sin sorpresas."
  />
</Base>
